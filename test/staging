#!/usr/bin/env bash

set -euo pipefail

IMAGE="${IMAGE:-}"
_SCAN="${STAGING_SCAN:-true}"
_ADVISE_GRYPE="${STAGING_ADVISE:-true}"
_ADVISE_SCOUT=true
_ADVISE_DIVE=false
_ADVISE_EXPLICIT=false
_YES=false

TRIVY_IMAGE=aquasec/trivy
TRIVY_TAG=0.62.1
GRYPE_IMAGE=anchore/grype
GRYPE_TAG=v0.87.0
DIVE_IMAGE=wagoodman/dive
DIVE_TAG=v0.13.1

TRIVY_CACHE_VOLUME=mdless-staging-trivy-cache
GRYPE_CACHE_VOLUME=mdless-staging-grype-cache

show_help() {
    cat <<'EOF'
Usage: test/staging [options] [IMAGE]

Options:
  --image IMAGE      Docker image under test
  --scan             Run Trivy scan (default)
  --no-scan          Skip Trivy scan; implies --no-advise unless --advise is set
  --advise [LIST]    Advisory scans: grype,scout,dive,all (default: grype,scout)
  --no-advise        Disable advisory scans
  --yes              Skip confirmation prompt
  --help|-h          Show this help and exit
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --image)
            IMAGE="$2"
            shift
            ;;
        --scan)
            _SCAN=true
            ;;
        --no-scan)
            _SCAN=false
            ;;
        --advise|--advice)
            _ADVISE_EXPLICIT=true
            if [[ $# -gt 1 && ! "$2" =~ ^-- ]]; then
                advisements="$2"
                shift
            else
                advisements="grype,scout"
            fi
            _ADVISE_GRYPE=false
            _ADVISE_SCOUT=false
            _ADVISE_DIVE=false
            IFS=',' read -ra adv_list <<< "$advisements"
            for adv in "${adv_list[@]}"; do
                case "$adv" in
                    grype) _ADVISE_GRYPE=true ;;
                    scout) _ADVISE_SCOUT=true ;;
                    dive) _ADVISE_DIVE=true ;;
                    all) _ADVISE_GRYPE=true; _ADVISE_SCOUT=true; _ADVISE_DIVE=true ;;
                    *) echo "Unknown advisement: $adv" >&2; exit 1 ;;
                esac
            done
            ;;
        --no-advise)
            _ADVISE_EXPLICIT=true
            _ADVISE_GRYPE=false
            _ADVISE_SCOUT=false
            _ADVISE_DIVE=false
            ;;
        --yes)
            _YES=true
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        -*)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
        *)
            IMAGE="$1"
            ;;
    esac
    shift
done

if [[ "${_SCAN}" == "false" && "${_ADVISE_EXPLICIT}" == "false" ]]; then
    _ADVISE_GRYPE=false
    _ADVISE_SCOUT=false
    _ADVISE_DIVE=false
fi

[[ -n "${IMAGE}" ]] || { echo "IMAGE is required" >&2; exit 1; }
docker image inspect "${IMAGE}" >/dev/null 2>&1 || { echo "Image not found: ${IMAGE}" >&2; exit 1; }

if [[ "${_YES}" != "true" ]]; then
    printf 'Type "yes" to proceed, or press Enter to abort: '
    read -r response
    [[ "${response}" == "yes" ]] || { echo "Aborted."; exit 1; }
fi

# Basic image smoke test.
docker run --rm --entrypoint /bin/sh "${IMAGE}" -c 'true'

if [[ "${_SCAN}" == "true" ]]; then
    _trivy_tar=$(mktemp /tmp/trivy-scan-XXXXXX.tar)
    trap 'rm -f "${_trivy_tar}"' EXIT
    docker image save "${IMAGE}" -o "${_trivy_tar}"
    docker run --rm \
        -v "${_trivy_tar}:/scan.tar:ro" \
        -v "${TRIVY_CACHE_VOLUME}:/root/.cache/trivy" \
        "${TRIVY_IMAGE}:${TRIVY_TAG}" image \
            --exit-code 1 \
            --ignore-unfixed \
            --severity HIGH,CRITICAL \
            --input /scan.tar
    rm -f "${_trivy_tar}"
    trap - EXIT
fi

if [[ "${_ADVISE_GRYPE}" == "true" ]]; then
    _grype_tar=$(mktemp /tmp/grype-scan-XXXXXX.tar)
    trap 'rm -f "${_grype_tar}"' EXIT
    docker image save "${IMAGE}" -o "${_grype_tar}"
    docker run --rm \
        -v "${_grype_tar}:/scan.tar:ro" \
        -v "${GRYPE_CACHE_VOLUME}:/root/.cache/grype" \
        "${GRYPE_IMAGE}:${GRYPE_TAG}" \
            docker-archive:/scan.tar || true
    rm -f "${_grype_tar}"
    trap - EXIT
fi

if [[ "${_ADVISE_SCOUT}" == "true" ]]; then
    docker scout cves "${IMAGE}" || true
fi

if [[ "${_ADVISE_DIVE}" == "true" ]]; then
    _dive_tar=$(mktemp /tmp/dive-scan-XXXXXX.tar)
    trap 'rm -f "${_dive_tar}"' EXIT
    docker save "${IMAGE}" > "${_dive_tar}"
    docker run --rm \
        -v "${_dive_tar}:/scan.tar:ro" \
        "${DIVE_IMAGE}:${DIVE_TAG}" \
            --source docker-archive \
            --ci \
            /scan.tar || true
    rm -f "${_dive_tar}"
    trap - EXIT
fi

echo "PASS: staging checks completed for ${IMAGE}"
