#!/bin/sh

# mdless integration test runner for the Docker wrapper image.

set -eu

IMAGE_NAME="${IMAGE_NAME:-1121citrus/mdless}"
IMAGE_TAG="${IMAGE_TAG:-${TAG:-test}}"
IMAGE="${IMAGE_NAME}:${IMAGE_TAG}"

fail() {
    echo "[FAIL] $*" >&2
    exit 1
}

assert_contains() {
    haystack="${1}"
    needle="${2}"
    label="${3}"

    echo "${haystack}" | grep -F -- "${needle}" >/dev/null 2>&1 || \
        fail "${label}: expected output to contain '${needle}'"
}

echo "[INFO] Testing mdless Docker image: ${IMAGE}"

echo "[INFO] Test 0: repository remains CLI-first"
[ ! -f docker-compose.yml ] || fail "docker-compose.yml should not exist for CLI-first workflow"

if ! docker info >/dev/null 2>&1; then
    fail "Docker daemon is not running"
fi

# If TAG is explicitly provided (from build script), skip building—the image should
# already exist. Otherwise, build it (for standalone test runs).
if [ -z "${TAG:-}" ]; then
    echo "[INFO] Building Docker image"
    docker buildx build --load --provenance=false --sbom=false -t "${IMAGE}" . >/dev/null
else
    echo "[INFO] Using pre-built image: ${IMAGE}"
fi

echo "[INFO] Test 1: file argument renders markdown"
file_output=$(docker run --rm -v "$(pwd)/test:/workspace:ro" "${IMAGE}" /workspace/sample.md)
assert_contains "${file_output}" "Sample markdown file for testing" "file render"

echo "[INFO] Test 2: stdin render works"
stdin_output=$(printf '# stdin heading\n\nbody\n' | docker run --rm -i "${IMAGE}")
assert_contains "${stdin_output}" "stdin heading" "stdin render"

echo "[INFO] Test 3: no args + no stdin prints usage and exits non-zero"
if no_input_output=$(docker run --rm "${IMAGE}" 2>&1); then
    fail "no-input usage: expected non-zero exit"
fi
assert_contains "${no_input_output}" "Usage:" "no-input usage"

echo "[INFO] Test 4: --help prints usage and exits successfully"
help_output=$(docker run --rm -i "${IMAGE}" --help 2>&1)
assert_contains "${help_output}" "Usage:" "help usage"

echo "[INFO] Test 5: direct mdless args pass through"
pass_through_output=$(docker run --rm -v "$(pwd)/test:/workspace:ro" "${IMAGE}" /workspace/sample.md)
assert_contains "${pass_through_output}" "Feature 1" "arg pass-through"

echo "[INFO] Test 6: container runs as non-root"
user_id=$(docker run --rm --entrypoint node "${IMAGE}" -p 'process.getuid()')
[ "${user_id}" = "10001" ] || fail "non-root runtime: expected uid 10001, got ${user_id}"

echo "[INFO] Test 7: empty piped stdin with no args returns usage and exit code 2"
empty_stdin_exit=0
empty_stdin_output=$(printf '' | docker run --rm -i "${IMAGE}" 2>&1) || empty_stdin_exit=$?
[ ${empty_stdin_exit} -eq 2 ] || fail "empty-stdin: expected exit code 2, got ${empty_stdin_exit}"
assert_contains "${empty_stdin_output}" "Usage:" "empty-stdin usage"

echo "[INFO] Test 8: mdless with non-existent file returns non-zero exit code"
if docker run --rm "${IMAGE}" /nonexistent/file.md >/dev/null 2>&1; then
    fail "mdless-nonexistent: expected non-zero exit code for missing file"
fi
# Expected: mdless returns non-zero; wrapper propagates it correctly

echo "[INFO] Test 9: invalid markdown renders successfully (mdless handles gracefully)"
invalid_md_output=$(printf '[[broken [[ markdown {{{' | docker run --rm -i "${IMAGE}")
# mdless renders gracefully even with malformed input; just verify output is produced
[ -n "${invalid_md_output}" ] || fail "invalid-markdown: expected output, got empty string"

echo "[INFO] Test 10: build help documents --advice and --cache"
build_help_output=$(./build --help 2>&1)
assert_contains "${build_help_output}" "--advice" "build help advice alias"
assert_contains "${build_help_output}" "--cache CACHE_RULES" "build help cache"

echo "[INFO] Test 11: staging help documents --scan and --advise"
staging_help_output=$(./test/staging --help 2>&1)
assert_contains "${staging_help_output}" "--scan" "staging scan option"
assert_contains "${staging_help_output}" "--advise" "staging advise option"

# Test image in the CI workflow can't have its provenance attested by Docker Scout because the
# image is built locally and not pushed to a registry, so this test is skipped in the CI context.
